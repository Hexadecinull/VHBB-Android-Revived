<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".ui.cbpsdb.CBPSDBDetails"
    tools:ignore="UseCompoundDrawables,ContentDescription,RtlHardcoded,RtlSymmetry">

    <androidx.cardview.widget.CardView
        android:id="@+id/details_cardview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/details_margin_edge"
        android:backgroundTint="@color/colorPrimary"
        app:cardCornerRadius="@dimen/details_corner_radius"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/ll_title"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_margin="12dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/image"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center_vertical"
                        android:src="@mipmap/ic_launcher_round" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingLeft="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/textview_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:text="@string/app_name"
                            android:textColor="@color/textColorTitle"
                            android:textSize="@dimen/text_title_big"
                            app:autoSizeMaxTextSize="@dimen/text_title_big"
                            app:autoSizeMinTextSize="12sp"
                            app:autoSizeStepGranularity="1sp"
                            app:autoSizeTextType="uniform" />

                        <TextView
                            android:id="@+id/textview_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorAccent"
                            android:textSize="@dimen/text_date" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:id="@+id/line1"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_below="@id/ll_title"
                    android:layout_marginTop="2dp"
                    android:background="@color/colorBackground" />

                <LinearLayout
                    android:id="@+id/ll_author"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/line1"
                    android:orientation="horizontal"
                    android:paddingLeft="12dp"
                    android:paddingTop="6dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:paddingRight="8dp"
                        android:text="@string/details_author"
                        android:textColor="@color/textColorDescription"
                        android:textSize="@dimen/text_details_header" />

                    <TextView
                        android:id="@+id/textview_author"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:lines="1"
                        android:textColor="@color/textColorTitle"
                        android:textSize="@dimen/text_details_item" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/ll_author"
                    android:orientation="horizontal"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:paddingRight="8dp"
                        android:text="@string/details_date"
                        android:textColor="@color/textColorDescription"
                        android:textSize="@dimen/text_details_header" />

                    <TextView
                        android:id="@+id/textview_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:textColor="@color/textColorTitle"
                        android:textSize="@dimen/text_details_item" />

                </LinearLayout>

                <View
                    android:id="@+id/line2"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_below="@id/ll_date"
                    android:background="@color/colorBackground" />

                <LinearLayout
                    android:id="@+id/ll_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/line2"
                    android:orientation="horizontal"
                    android:paddingLeft="12dp"
                    android:paddingTop="6dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/textview_options_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:paddingRight="8dp"
                        android:text="@string/details_options"
                        android:textColor="@color/textColorDescription"
                        android:textSize="@dimen/text_details_header" />

                    <TextView
                        android:id="@+id/textview_options"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:textColor="@color/textColorTitle"
                        android:textSize="@dimen/text_details_item" />

                </LinearLayout>

                <View
                    android:id="@+id/line_source"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_below="@id/ll_options"
                    android:background="@color/colorBackground" />

                <LinearLayout
                    android:id="@+id/ll_source"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/line_source"
                    android:orientation="horizontal"
                    android:paddingLeft="12dp"
                    android:paddingTop="6dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/button_source"
                        style="@style/Widget.AppCompat.Button.Colored"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/details_source" />

                    <TextView
                        android:id="@+id/textview_closed_source"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/details_closed_source"
                        android:textColor="@color/textColorDescription"
                        android:textSize="@dimen/text_details_header"
                        android:textStyle="italic" />

                </LinearLayout>

                <View
                    android:id="@+id/line_readme"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_below="@id/ll_source"
                    android:background="@color/colorBackground" />

                <LinearLayout
                    android:id="@+id/ll_readme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/line_readme"
                    android:orientation="vertical"
                    android:paddingLeft="12dp"
                    android:paddingTop="6dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/details_readme"
                        android:textColor="@color/textColorDescription"
                        android:textSize="@dimen/text_details_header"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:id="@+id/textview_readme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textColorTitle"
                        android:textSize="@dimen/text_description" />

                </LinearLayout>

            </RelativeLayout>

        </ScrollView>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|bottom"
            android:layout_margin="12dp">

            <ImageButton
                android:id="@+id/download"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_toRightOf="@id/downloadData"
                android:background="@android:color/transparent"
                android:scaleX="2"
                android:scaleY="2"
                android:src="@drawable/ic_download_circle_24dp" />

            <ImageButton
                android:id="@+id/downloadData"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginRight="6dp"
                android:background="@android:color/transparent"
                android:scaleX="2"
                android:scaleY="2"
                android:src="@drawable/ic_download_data_circle_24dp" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
